---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allPosts = (await getCollection('posts')).filter(p => !p.data.draft);

allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const postsByYear: Record<string, typeof allPosts> = {};
for (const post of allPosts) {
  const year = new Date(post.data.date).getFullYear().toString();
  if (!postsByYear[year]) postsByYear[year] = [];
  postsByYear[year].push(post);
}

const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));
const currentYear = years[0];

const slugs = allPosts.map(p => p.slug);

const siteJsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Curiosity Log",
  "description": "Small questions about everyday things. A minimalist inquiry into the mechanics of the ordinary.",
  "url": "https://curiositylog.com",
  "author": {
    "@type": "Organization",
    "name": "Curiosity Log"
  },
  "blogPost": allPosts.slice(0, 10).map(p => ({
    "@type": "BlogPosting",
    "headline": p.data.title,
    "description": p.data.description,
    "datePublished": new Date(p.data.date).toISOString(),
    "url": `https://curiositylog.com/posts/${p.slug}`
  }))
};

function formatMonthDay(dateStr: string) {
  const d = new Date(dateStr);
  const mm = String(d.getMonth() + 1).padStart(2, '0');
  const dd = String(d.getDate()).padStart(2, '0');
  return `${mm}.${dd}`;
}
---

<Layout
  title="Curiosity Log — Small questions about everyday things"
  description="A minimalist inquiry into the mechanics of the everyday. Small questions about ordinary things."
>
  <script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} />

  <script define:vars={{ slugs }}>
    window.__POSTS__ = slugs;
  </script>

  <div class="page-wrapper">
    <aside class="vertical-text" aria-hidden="true">
      <span>OBSERVATORY OF THE ORDINARY</span>
    </aside>

    <div class="page-content">
      <section class="hero-section">
        <p class="label hero-label">Introduction</p>
        <h1 class="hero-heading">
          Small questions about <em>everyday</em> things. Inquiry into the ordinary.
        </h1>
        <div class="hero-accent-line"></div>
        <div class="hero-actions">
          <button class="surprise-btn" id="surpriseBtn">
            <span>Surprise Me</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </button>
        </div>
      </section>

      <div class="vol-tag" aria-hidden="true">Vol. 01</div>

      {years.map((year, i) => (
        <section class="archive-section" style={`--section-index:${i}`}>
          <div class="archive-year-row">
            <h2 class="archive-year">{year}</h2>
            <span class="label archive-label">
              {year === currentYear ? '— current archive' : '— previous archive'}
            </span>
          </div>
          <div class="archive-list">
            {postsByYear[year].map((post) => (
              <a href={`/posts/${post.slug}`} class="archive-item">
                <span class="archive-date label">{formatMonthDay(post.data.date)}</span>
                <span class="archive-title">{post.data.title}</span>
                <span class="archive-arrow" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <line x1="7" y1="17" x2="17" y2="7"/>
                    <polyline points="7 7 17 7 17 17"/>
                  </svg>
                </span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</Layout>

<style>
  .page-wrapper {
    position: relative;
    display: flex;
  }

  .vertical-text {
    position: fixed;
    left: 0;
    top: 50%;
    transform: translateY(-50%) rotate(-90deg);
    transform-origin: center center;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--divider);
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    writing-mode: vertical-rl;
    transform: none;
    left: 16px;
    top: 50%;
  }

  .page-content {
    flex: 1;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 calc(var(--spacing-unit) * 3);
  }

  .hero-section {
    padding-top: calc(var(--spacing-unit) * 8);
    padding-bottom: calc(var(--spacing-unit) * 10);
    border-bottom: 1px solid var(--divider);
    margin-bottom: calc(var(--spacing-unit) * 8);
    position: relative;
    animation: fade-up 0.6s ease both;
  }

  .hero-label {
    display: block;
    margin-bottom: calc(var(--spacing-unit) * 3);
  }

  .hero-heading {
    font-family: var(--font-body);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 300;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--text);
    max-width: 600px;
    margin-bottom: calc(var(--spacing-unit) * 4);
  }

  .hero-heading em {
    font-style: italic;
    font-weight: 300;
  }

  .hero-accent-line {
    width: 40px;
    height: 2px;
    background: var(--accent);
    margin-bottom: calc(var(--spacing-unit) * 5);
    transform-origin: left;
    animation: line-grow 0.5s 0.3s ease both;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: calc(var(--spacing-unit) * 3);
  }

  .surprise-btn {
    display: inline-flex;
    align-items: center;
    gap: calc(var(--spacing-unit));
    background: none;
    border: 1px solid var(--divider);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: calc(var(--spacing-unit) * 1.25) calc(var(--spacing-unit) * 2);
    transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }

  .surprise-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-dim);
  }

  .vol-tag {
    position: fixed;
    left: 16px;
    bottom: 80px;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    color: var(--divider);
    text-transform: uppercase;
    user-select: none;
    pointer-events: none;
  }

  .archive-section {
    margin-bottom: calc(var(--spacing-unit) * 10);
    animation: fade-up 0.5s ease both;
    animation-delay: calc(var(--section-index, 0) * 80ms + 200ms);
  }

  .archive-year-row {
    display: flex;
    align-items: baseline;
    gap: calc(var(--spacing-unit) * 2);
    margin-bottom: calc(var(--spacing-unit) * 3);
  }

  .archive-year {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .archive-label {
    font-size: 0.6rem;
    letter-spacing: 0.15em;
  }

  .archive-list {
    border-top: 1px solid var(--divider);
  }

  .archive-item {
    display: flex;
    align-items: center;
    gap: calc(var(--spacing-unit) * 3);
    padding: calc(var(--spacing-unit) * 2.5) calc(var(--spacing-unit) * 2);
    border-bottom: 1px solid var(--divider);
    text-decoration: none;
    transition: background-color 0.22s ease, transform 0.22s ease;
    cursor: pointer;
    position: relative;
  }

  .archive-item:hover {
    background: var(--accent-dim);
    transform: translateX(3px);
  }

  .archive-item:hover .archive-arrow {
    opacity: 1;
    transform: translate(2px, -2px);
    color: var(--accent);
  }

  .archive-item:hover .archive-title {
    color: var(--text);
  }

  .archive-date {
    min-width: 40px;
    font-size: 0.6rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .archive-title {
    flex: 1;
    font-size: 1rem;
    font-weight: 400;
    color: var(--text);
    transition: color 0.15s ease;
    line-height: 1.4;
  }

  .archive-arrow {
    opacity: 0.3;
    color: var(--text-muted);
    flex-shrink: 0;
    transition: opacity 0.15s ease, transform 0.15s ease, color 0.15s ease;
    display: flex;
    align-items: center;
  }

  @media (max-width: 768px) {
    .vertical-text,
    .vol-tag {
      display: none;
    }

    .hero-heading {
      font-size: 1.75rem;
    }
  }

  @media (max-width: 480px) {
    .archive-date {
      display: none;
    }

    .archive-item {
      gap: calc(var(--spacing-unit) * 2);
    }
  }
</style>

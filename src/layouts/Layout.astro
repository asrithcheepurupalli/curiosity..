---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  author?: string;
}

const {
  title = 'Curiosity Log',
  description = 'Small questions about everyday things.',
  image = '/og-image.png',
  type = 'website',
  publishedTime,
  author = 'Curiosity Log',
} = Astro.props;

const siteUrl = Astro.site ?? 'https://curiositylog.com';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogImage = new URL(image, siteUrl);
const pageTitle = title.includes('Curiosity Log') ? title : `${title} — Curiosity Log`;
---
<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#FAFAF7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0F0F10" media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title="Curiosity Log" href="/rss.xml" />

    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={pageTitle} />
    <meta property="og:site_name" content="Curiosity Log" />
    <meta property="og:locale" content="en_US" />
    {type === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {type === 'article' && (
      <meta property="article:author" content={author} />
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={pageTitle} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Inter:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#main-content" class="skip-link sr-only">Skip to main content</a>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="logo" aria-label="Curiosity Log home">
          <span class="logo-wordmark">
            <span class="logo-word">curiosity</span><span class="logo-period">.</span>
          </span>
        </a>
        <nav class="header-actions">
          <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
            <span class="icon-sun" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="5"/>
                <line x1="12" y1="1" x2="12" y2="3"/>
                <line x1="12" y1="21" x2="12" y2="23"/>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                <line x1="1" y1="12" x2="3" y2="12"/>
                <line x1="21" y1="12" x2="23" y2="12"/>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
              </svg>
            </span>
            <span class="icon-moon" aria-hidden="true" style="display:none">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
            </span>
          </button>
          <button class="menu-btn" id="menuToggle" aria-label="Menu" aria-expanded="false">
            <svg width="18" height="14" viewBox="0 0 18 14" fill="none" stroke="currentColor" stroke-width="1.5">
              <line x1="0" y1="1" x2="18" y2="1"/>
              <line x1="0" y1="7" x2="18" y2="7"/>
              <line x1="0" y1="13" x2="18" y2="13"/>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <nav class="mobile-menu" id="mobileMenu" aria-hidden="true">
      <a href="/" class="mobile-nav-link">Archive</a>
      <a href="/about" class="mobile-nav-link">About</a>
      <a href="/rss.xml" class="mobile-nav-link">RSS</a>
      <button class="surprise-btn-mobile" id="surpriseBtnMobile">Surprise Me →</button>
    </nav>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-inner">
          <div class="footer-about">
            <p class="label">About the Log</p>
            <p class="footer-desc">A minimalist inquiry into the mechanics of the everyday. We document the things often overlooked, seeking meaning in the mundane.</p>
          </div>
          <div class="footer-links">
            <p class="label">Explore</p>
            <nav class="footer-nav">
              <a href="/about">About the Log</a>
              <a href="/rss.xml">RSS Feed</a>
            </nav>
          </div>
        </div>
        <div class="footer-bottom">
          <span class="label">&copy; {new Date().getFullYear()} Curiosity Log</span>
          <nav class="footer-bottom-nav">
            <a href="/" class="label">Archive</a>
            <a href="/rss.xml" class="label">RSS</a>
            <a href="/about" class="label">About</a>
          </nav>
        </div>
      </div>
    </footer>

    <script>
      const html = document.documentElement;
      const themeToggle = document.getElementById('themeToggle');
      const iconSun = themeToggle?.querySelector('.icon-sun') as HTMLElement | null;
      const iconMoon = themeToggle?.querySelector('.icon-moon') as HTMLElement | null;
      const menuToggle = document.getElementById('menuToggle');
      const mobileMenu = document.getElementById('mobileMenu');
      const surpriseBtnMobile = document.getElementById('surpriseBtnMobile');

      const saved = localStorage.getItem('theme') || 'light';
      html.setAttribute('data-theme', saved);
      updateIcons(saved);

      themeToggle?.addEventListener('click', () => {
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        updateIcons(next);
      });

      function updateIcons(theme: string) {
        if (!iconSun || !iconMoon) return;
        if (theme === 'dark') {
          iconSun.style.display = 'none';
          iconMoon.style.display = 'block';
        } else {
          iconSun.style.display = 'block';
          iconMoon.style.display = 'none';
        }
      }

      menuToggle?.addEventListener('click', () => {
        const isOpen = mobileMenu?.classList.contains('is-open');
        mobileMenu?.classList.toggle('is-open');
        menuToggle.setAttribute('aria-expanded', String(!isOpen));
        mobileMenu?.setAttribute('aria-hidden', String(isOpen));
      });

      async function goRandom() {
        const posts = (window as any).__POSTS__;
        if (!posts || posts.length === 0) return;
        const random = posts[Math.floor(Math.random() * posts.length)];
        window.location.href = `/posts/${random}`;
      }

      document.getElementById('surpriseBtn')?.addEventListener('click', goRandom);
      surpriseBtnMobile?.addEventListener('click', goRandom);
    </script>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--divider);
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 calc(var(--spacing-unit) * 3);
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .logo-wordmark {
    position: relative;
    display: inline-flex;
    align-items: baseline;
    line-height: 1;
  }

  .logo-word {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--text);
    text-shadow: 0 0 12px rgba(0,0,0,0.15), 0 0 24px rgba(0,0,0,0.08);
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }

  .logo-period {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--accent);
    text-shadow: 0 0 6px rgba(46,204,113,0.95), 0 0 18px rgba(46,204,113,0.75), 0 0 45px rgba(46,204,113,0.45);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: calc(var(--spacing-unit) * 2);
  }

  .theme-toggle,
  .menu-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: calc(var(--spacing-unit) * 1.75);
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease;
    border-radius: 4px;
  }

  .theme-toggle:hover,
  .menu-btn:hover {
    color: var(--text);
  }

  .mobile-menu {
    position: fixed;
    top: 56px;
    right: 0;
    width: min(220px, 75vw);
    background: var(--bg);
    border-left: 1px solid var(--divider);
    border-bottom: 1px solid var(--divider);
    padding: calc(var(--spacing-unit) * 3);
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing-unit) * 2);
    transform: translateX(100%);
    transition: transform 0.25s ease;
    z-index: 99;
  }

  .mobile-menu.is-open {
    transform: translateX(0);
  }

  .mobile-nav-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: color 0.2s ease;
    padding: calc(var(--spacing-unit) * 1.5) 0;
    min-height: 44px;
    display: flex;
    align-items: center;
  }

  .mobile-nav-link:hover {
    color: var(--text);
  }

  .surprise-btn-mobile {
    background: none;
    border: 1px solid var(--divider);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    padding: calc(var(--spacing-unit) * 1.5) calc(var(--spacing-unit) * 2);
    min-height: 44px;
    text-align: left;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .surprise-btn-mobile:hover {
    background: var(--accent-dim);
    border-color: var(--accent);
  }

  main {
    min-height: calc(100vh - 56px - 200px);
  }

  .site-footer {
    border-top: 1px solid var(--divider);
    padding: calc(var(--spacing-unit) * 8) 0 calc(var(--spacing-unit) * 4);
    margin-top: calc(var(--spacing-unit) * 12);
  }

  .footer-inner {
    display: flex;
    gap: calc(var(--spacing-unit) * 8);
    margin-bottom: calc(var(--spacing-unit) * 8);
  }

  .footer-about {
    flex: 1;
  }

  .footer-about .label {
    display: block;
    margin-bottom: calc(var(--spacing-unit) * 2);
  }

  .footer-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 280px;
  }

  .footer-links {
    min-width: 160px;
  }

  .footer-links .label {
    display: block;
    margin-bottom: calc(var(--spacing-unit) * 2);
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing-unit));
  }

  .footer-nav a {
    font-size: 0.9rem;
    color: var(--text-muted);
    transition: color 0.2s ease;
  }

  .footer-nav a:hover {
    color: var(--text);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: calc(var(--spacing-unit) * 4);
    border-top: 1px solid var(--divider);
  }

  .footer-bottom-nav {
    display: flex;
    gap: calc(var(--spacing-unit) * 3);
  }

  .footer-bottom-nav a {
    color: var(--text-muted);
    transition: color 0.2s ease;
  }

  .footer-bottom-nav a:hover {
    color: var(--text);
  }

  @media (max-width: 480px) {
    .footer-inner {
      flex-direction: column;
      gap: calc(var(--spacing-unit) * 5);
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: calc(var(--spacing-unit) * 2);
    }
  }
</style>
